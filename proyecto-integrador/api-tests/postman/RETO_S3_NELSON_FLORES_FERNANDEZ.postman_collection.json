  "item": [
    {
      "name": "01 · GET Listar usuarios",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Devuelve la lista completa de 10 usuarios', function () {",
              "    const posts = pm.response.json();",
              "    pm.expect(posts).to.be.an('array');",
              "    pm.expect(posts).to.have.lengthOf(10);",
              "});",
              "",
              "pm.test('Responde en menos de 2 segundos', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 · GET Detalle de un post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Contrato de la API: si la estructura cambia, este test falla",
              "const postSchema = {",
              "    type: 'object',",
              "    required: ['id', 'name','username', 'email'],",
              "    properties: {",
              "        id: { type: 'integer' },",
              "        name: { type: 'string' },",
              "        username: { type: 'string' },",
              "        email: { type: 'string' }",
              "    }",
              "};",
              "",
              "pm.test('El post cumple el contrato (JSON Schema) id, name, username, email', function () {",
              "    pm.response.to.have.jsonSchema(postSchema);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "1"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 · POST Crear post",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Se ejecuta ANTES de enviar el request: genera un título único",
              "const name = \"Nelson \" + Date.now();",
              "pm.collectionVariables.set(\"dynamic_name\", name);",
              "console.log('Título generado:', name);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('El name enviado coincide con el devuelto', function () {",
              "    const enviado = pm.collectionVariables.get('dynamic_name');",
              "    pm.expect(pm.response.json().name).to.eql(enviado);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"{{dynamic_name}}\",\n    \"username\": \"nelson\",\n    \"email\": \"nelson@test.com\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
